{
    "id": {
        "type": "str",
        "default": "recommender_agent_ffff",
        "private": false,
        "sampling": "default",
        "description": "Unique id of recommender_agent"
    },
    "type": {
        "type": "str",
        "default": "Random Recommendation",
        "private": false,
        "sampling": "default",
        "choices": ["Popularity Recommendation", "Random Recommendation"],
        "description": "Algorithm of recommendation system"
    },
    "limit": {
        "type": "int",
        "default": "5",
        "private": false,
        "sampling": "default",
        "description": "Number of recommended contents"
    },
    "recommendations":{
        "type": "dict",
        "default": {},
        "private": false,
        "sampling": "none",
        "description": "Dictionary of post content pushed by recommendation algorithm. The key is the note ID, the value is a dictionary containing note ID, title, content, publisher ID, publisher nickname, publication time, and other fields."
    },
    "current_tweets":{
        "type": "dict",
        "default": {},
        "private": false,
        "sampling": "none",
        "description": "Dictionary of current notes published by the agent."
    }
}


